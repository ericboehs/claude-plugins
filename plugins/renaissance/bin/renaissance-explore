#!/usr/bin/env osascript -l JavaScript

// Renaissance Network Explorer
// Injects a network interceptor into Safari to capture all fetch/XHR calls
// on the Renaissance student progress page. Used for API reverse-engineering.
//
// Usage:
//   ./bin/renaissance-explore [command]
//
// Commands:
//   login     - Log into Renaissance via Safari (uses 1Password)
//   inject    - Inject network interceptor into current Renaissance tab
//   capture   - Read back captured network calls
//   navigate  - Go to the completed work page
//   explore   - Full flow: login if needed, navigate, inject, wait, capture
//   dump      - Dump current page HTML source

const app = Application("Safari");
app.includeStandardAdditions = true;

const RENAISSANCE_BASE = "https://global-zone05.renaissance-go.com";
const LOGIN_URL = "https://login.renaissance.com";
const TARGET_URL = RENAISSANCE_BASE + "/studentprogress/my-completed-work";
const OP_ITEM = "allieboehs"; // 1Password item name

// --- Safari Tab Helpers ---

function findRenaissanceTab() {
  for (let w = 0; w < app.windows.length; w++) {
    const win = app.windows[w];
    for (let t = 0; t < win.tabs.length; t++) {
      const tab = win.tabs[t];
      const url = tab.url();
      if (url && (url.includes("renaissance") || url.includes("renaissance-go.com"))) {
        win.currentTab = tab;
        return { window: win, tab: tab, index: t };
      }
    }
  }
  return null;
}

function getOrCreateTab() {
  const existing = findRenaissanceTab();
  if (existing) return existing;

  // Create new tab in front window
  const win = app.windows[0];
  const newTab = app.Tab({ url: "about:blank" });
  win.tabs.push(newTab);
  win.currentTab = newTab;
  delay(1);
  return { window: win, tab: newTab, index: win.tabs.length - 1 };
}

function doJS(tab, js) {
  return app.doJavaScript(js, { in: tab });
}

function waitForPageLoad(tab, maxWait) {
  const limit = maxWait || 15;
  for (let i = 0; i < limit; i++) {
    delay(1);
    try {
      const ready = doJS(tab, "document.readyState");
      if (ready === "complete") return true;
    } catch(e) { /* page still loading */ }
  }
  return false;
}

function currentUrl(tab) {
  try { return tab.url(); } catch(e) { return ""; }
}

// --- 1Password Credentials ---

function getCredentials() {
  const opApp = Application.currentApplication();
  opApp.includeStandardAdditions = true;

  // Get 1Password master password from Keychain
  let masterPass;
  try {
    masterPass = opApp.doShellScript(
      'security find-generic-password -s "op-master" -w'
    );
  } catch(e) {
    return { error: "Could not get 1Password master from Keychain: " + e.message };
  }

  // Sign in to 1Password
  let sessionToken;
  try {
    sessionToken = opApp.doShellScript(
      'printf "%s" ' + quotedArg(masterPass) + ' | op signin --account my --raw 2>/dev/null'
    );
  } catch(e) {
    return { error: "1Password signin failed: " + e.message };
  }

  // Get username and password
  const env = "OP_SESSION_my=" + sessionToken;
  let username, password;
  try {
    username = opApp.doShellScript(
      env + ' op item get ' + quotedArg(OP_ITEM) + ' --fields username --reveal 2>/dev/null'
    );
    password = opApp.doShellScript(
      env + ' op item get ' + quotedArg(OP_ITEM) + ' --fields password --reveal 2>/dev/null'
    );
  } catch(e) {
    return { error: "Could not get credentials from 1Password: " + e.message };
  }

  return { username: username.trim(), password: password.trim() };
}

function quotedArg(s) {
  return "'" + s.replace(/'/g, "'\\''") + "'";
}

// --- Login ---

function doLogin() {
  const { tab } = getOrCreateTab();
  const creds = getCredentials();
  if (creds.error) return creds.error;

  // Navigate to login
  tab.url = LOGIN_URL;
  waitForPageLoad(tab, 20);
  delay(2); // extra time for JS-heavy login page

  // Check if already logged in (redirected away from login)
  const url = currentUrl(tab);
  if (!url.includes("login.renaissance.com") && url.includes("renaissance")) {
    return "Already logged in! Current URL: " + url;
  }

  // Fill in credentials and submit
  // Renaissance login is a React/SPA app - need to find the right selectors
  const fillResult = doJS(tab, `
    (function() {
      // Try common input selectors for Renaissance login
      const selectors = [
        { user: 'input[name="username"]', pass: 'input[name="password"]' },
        { user: 'input[type="text"]', pass: 'input[type="password"]' },
        { user: '#username', pass: '#password' },
        { user: '[data-testid="username"]', pass: '[data-testid="password"]' },
      ];

      for (const sel of selectors) {
        const userEl = document.querySelector(sel.user);
        const passEl = document.querySelector(sel.pass);
        if (userEl && passEl) {
          // React-compatible value setting
          const nativeInputValueSetter = Object.getOwnPropertyDescriptor(
            window.HTMLInputElement.prototype, 'value'
          ).set;
          nativeInputValueSetter.call(userEl, ${JSON.stringify(creds.username)});
          userEl.dispatchEvent(new Event('input', { bubbles: true }));
          userEl.dispatchEvent(new Event('change', { bubbles: true }));

          nativeInputValueSetter.call(passEl, ${JSON.stringify(creds.password)});
          passEl.dispatchEvent(new Event('input', { bubbles: true }));
          passEl.dispatchEvent(new Event('change', { bubbles: true }));

          // Find and click submit
          const submitBtn = document.querySelector(
            'button[type="submit"], input[type="submit"], [data-testid="login-button"]'
          );
          if (submitBtn) submitBtn.click();

          return JSON.stringify({
            status: "filled",
            userSelector: sel.user,
            passSelector: sel.pass,
            hasSubmit: !!submitBtn
          });
        }
      }

      // Report what we found on the page for debugging
      const inputs = Array.from(document.querySelectorAll('input')).map(i => ({
        type: i.type, name: i.name, id: i.id, placeholder: i.placeholder
      }));
      const buttons = Array.from(document.querySelectorAll('button')).map(b => ({
        type: b.type, text: b.textContent.trim().substring(0, 50), className: b.className
      }));
      return JSON.stringify({ status: "no_match", inputs: inputs, buttons: buttons });
    })()
  `);

  // Wait for navigation after login
  delay(5);
  waitForPageLoad(tab, 15);

  const finalUrl = currentUrl(tab);
  return "Login attempt complete.\nFill result: " + fillResult + "\nCurrent URL: " + finalUrl;
}

// --- Network Interceptor ---

const INTERCEPTOR_JS = `
(function() {
  if (window.__renaissanceInterceptor) {
    return JSON.stringify({ status: "already_injected", captureCount: window.__renaissanceCalls.length });
  }

  window.__renaissanceCalls = [];
  window.__renaissanceInterceptor = true;

  // --- Intercept fetch() ---
  const origFetch = window.fetch;
  window.fetch = async function(...args) {
    const req = args[0];
    const opts = args[1] || {};
    const url = typeof req === 'string' ? req : req.url;
    const method = opts.method || (typeof req === 'object' ? req.method : 'GET') || 'GET';
    const headers = opts.headers || {};

    let body = opts.body || null;
    if (body && typeof body !== 'string') {
      try { body = JSON.stringify(body); } catch(e) { body = String(body); }
    }

    const entry = {
      type: 'fetch',
      timestamp: new Date().toISOString(),
      method: method.toUpperCase(),
      url: url,
      requestHeaders: headers,
      requestBody: body
    };

    try {
      const resp = await origFetch.apply(this, args);
      entry.status = resp.status;
      entry.responseHeaders = Object.fromEntries(resp.headers.entries());
      entry.responseUrl = resp.url;

      // Clone and capture response body
      const clone = resp.clone();
      try {
        const text = await clone.text();
        entry.responseBody = text.substring(0, 5000); // cap at 5KB
        entry.responseSize = text.length;
      } catch(e) {
        entry.responseBody = "(could not read body)";
      }

      window.__renaissanceCalls.push(entry);
      return resp;
    } catch(err) {
      entry.error = err.message;
      window.__renaissanceCalls.push(entry);
      throw err;
    }
  };

  // --- Intercept XMLHttpRequest ---
  const origOpen = XMLHttpRequest.prototype.open;
  const origSend = XMLHttpRequest.prototype.send;
  const origSetHeader = XMLHttpRequest.prototype.setRequestHeader;

  XMLHttpRequest.prototype.open = function(method, url) {
    this.__interceptMeta = { method: method, url: url, headers: {} };
    return origOpen.apply(this, arguments);
  };

  XMLHttpRequest.prototype.setRequestHeader = function(key, val) {
    if (this.__interceptMeta) this.__interceptMeta.headers[key] = val;
    return origSetHeader.apply(this, arguments);
  };

  XMLHttpRequest.prototype.send = function(body) {
    const meta = this.__interceptMeta || {};
    const entry = {
      type: 'xhr',
      timestamp: new Date().toISOString(),
      method: (meta.method || 'GET').toUpperCase(),
      url: meta.url || '',
      requestHeaders: meta.headers || {},
      requestBody: body ? String(body).substring(0, 2000) : null
    };

    this.addEventListener('load', function() {
      entry.status = this.status;
      entry.responseHeaders = this.getAllResponseHeaders();
      try {
        entry.responseBody = this.responseText.substring(0, 5000);
        entry.responseSize = this.responseText.length;
      } catch(e) {
        entry.responseBody = "(could not read)";
      }
      window.__renaissanceCalls.push(entry);
    });

    this.addEventListener('error', function() {
      entry.error = 'XHR error';
      window.__renaissanceCalls.push(entry);
    });

    return origSend.apply(this, arguments);
  };

  return JSON.stringify({ status: "injected", message: "Network interceptor active. Interact with the page, then run 'capture' to see calls." });
})()
`;

function injectInterceptor() {
  const found = findRenaissanceTab();
  if (!found) return "No Renaissance tab found in Safari. Run 'login' or 'navigate' first.";

  const result = doJS(found.tab, INTERCEPTOR_JS);
  return "Interceptor: " + result;
}

// --- Capture ---

function captureNetworkCalls(opts) {
  const found = findRenaissanceTab();
  if (!found) return "No Renaissance tab found.";

  const raw = doJS(found.tab, `
    (function() {
      const calls = window.__renaissanceCalls || [];
      if (calls.length === 0) return JSON.stringify({ count: 0, calls: [] });

      // Filter out noise (static assets, analytics, etc.)
      const interesting = calls.filter(c => {
        const url = c.url || '';
        if (url.includes('.js') || url.includes('.css') || url.includes('.png') ||
            url.includes('.svg') || url.includes('.woff') || url.includes('.ico')) return false;
        if (url.includes('google') || url.includes('analytics') ||
            url.includes('tracking') || url.includes('segment')) return false;
        return true;
      });

      return JSON.stringify({
        count: calls.length,
        filteredCount: interesting.length,
        calls: interesting
      }, null, 2);
    })()
  `);

  return raw;
}

// --- Navigate ---

function navigateToCompletedWork() {
  const { tab } = getOrCreateTab();
  tab.url = TARGET_URL;
  waitForPageLoad(tab, 20);
  delay(3); // SPA rendering
  const url = currentUrl(tab);

  // Check if we got redirected to login
  if (url.includes("login")) {
    return "Redirected to login. Run 'login' first.\nURL: " + url;
  }

  return "Navigated to: " + url;
}

// --- Dump Page Source ---

function dumpPageSource() {
  const found = findRenaissanceTab();
  if (!found) return "No Renaissance tab found.";

  const info = doJS(found.tab, `
    JSON.stringify({
      url: window.location.href,
      title: document.title,
      bodyLength: document.body.innerHTML.length,
      // Get a structural overview instead of full HTML
      headings: Array.from(document.querySelectorAll('h1,h2,h3,h4')).map(h => h.textContent.trim()),
      links: Array.from(document.querySelectorAll('a[href]')).slice(0, 30).map(a => ({
        text: a.textContent.trim().substring(0, 60),
        href: a.href
      })),
      forms: Array.from(document.querySelectorAll('form')).map(f => ({
        action: f.action, method: f.method,
        inputs: Array.from(f.querySelectorAll('input,select,textarea')).map(i => ({
          type: i.type, name: i.name, id: i.id
        }))
      })),
      tables: Array.from(document.querySelectorAll('table')).map(t => ({
        rows: t.rows.length,
        headers: Array.from(t.querySelectorAll('th')).map(th => th.textContent.trim())
      })),
      // Any visible data elements
      dataElements: Array.from(document.querySelectorAll('[class*="data"],[class*="score"],[class*="quiz"],[class*="book"],[class*="reading"],[class*="points"],[class*="level"]')).slice(0, 20).map(el => ({
        tag: el.tagName, className: el.className, text: el.textContent.trim().substring(0, 100)
      }))
    }, null, 2)
  `);

  return info;
}

// --- Full Explore Flow ---

function explore() {
  let output = [];

  // Check for existing Renaissance tab
  const existing = findRenaissanceTab();
  if (existing) {
    const url = currentUrl(existing.tab);
    output.push("Found Renaissance tab: " + url);

    if (url.includes("login")) {
      output.push("\n--- Logging in ---");
      output.push(doLogin());
    }
  } else {
    output.push("No Renaissance tab found. Logging in...");
    output.push(doLogin());
  }

  // Navigate to completed work
  output.push("\n--- Navigating to completed work ---");
  output.push(navigateToCompletedWork());

  // Inject interceptor
  output.push("\n--- Injecting network interceptor ---");
  output.push(injectInterceptor());

  // Dump page structure
  output.push("\n--- Page structure ---");
  output.push(dumpPageSource());

  output.push("\n--- Next steps ---");
  output.push("The interceptor is now active. Click around the page (quizzes, books, etc.)");
  output.push("then run: ./bin/renaissance-explore capture");

  return output.join("\n");
}

// --- Clear Captured Calls ---

function clearCapture() {
  const found = findRenaissanceTab();
  if (!found) return "No Renaissance tab found.";

  doJS(found.tab, "window.__renaissanceCalls = []; 'cleared'");
  return "Capture buffer cleared.";
}

// --- Main ---

function run(argv) {
  const command = argv[0] || "explore";

  switch (command) {
    case "login":    return doLogin();
    case "inject":   return injectInterceptor();
    case "capture":  return captureNetworkCalls();
    case "navigate": return navigateToCompletedWork();
    case "dump":     return dumpPageSource();
    case "explore":  return explore();
    case "clear":    return clearCapture();
    default:
      return [
        "Renaissance Network Explorer",
        "",
        "Usage: renaissance-explore [command]",
        "",
        "Commands:",
        "  explore   - Full flow: login, navigate, inject interceptor, dump page (default)",
        "  login     - Log into Renaissance via 1Password",
        "  navigate  - Go to the completed work page",
        "  inject    - Inject network interceptor into current tab",
        "  capture   - Read back captured network calls (JSON)",
        "  clear     - Clear captured calls buffer",
        "  dump      - Dump current page structure (headings, links, tables, etc.)",
        "  help      - Show this help",
      ].join("\n");
  }
}
